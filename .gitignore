# Personal data — NEVER commit anything under data/open-calls/
# (open call configs, photos, results, strategic briefs, jury research, rankings, etc.)
# Whitelist only the public example-template/ used as a reference.
/data/open-calls/*
!/data/open-calls/.gitkeep
!/data/open-calls/example-template
!/data/open-calls/example-template/**

# Test photos (separate scope, also ignored)
data/test-photos/*

# Temp
tmp/
temp/
*.tmp

# External tool artifacts (claude-mem, mempalace, etc.)
chroma.sqlite3
entities.json
mempalace.yaml

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Criteria Reasoning Schema",
  "description": "Schema for Art Critic's criteria reasoning output (criteria-reasoning.md). Conversational discovery layer, Cycle 1.",
  "type": "object",
  "required": ["criteria", "userContext", "openCallJsonPath"],
  "additionalProperties": false,
  "properties": {
    "criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["name", "weight", "motivation"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "description": "Criterion name"
          },
          "weight": {
            "type": "number",
            "minimum": 1,
            "maximum": 100,
            "description": "Weight percentage"
          },
          "motivation": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000,
            "description": "Why this criterion and this weight"
          }
        }
      }
    },
    "userContext": {
      "type": "object",
      "required": ["bodyOfWork", "intention"],
      "additionalProperties": false,
      "properties": {
        "bodyOfWork": {
          "type": "string",
          "minLength": 5,
          "maxLength": 2000,
          "description": "What the photographer has or intends to shoot"
        },
        "intention": {
          "type": "string",
          "minLength": 5,
          "maxLength": 2000,
          "description": "What they want to express"
        },
        "constraints": {
          "type": "string",
          "maxLength": 1000,
          "description": "Format, quantity, technical limits"
        }
      }
    },
    "openCallJsonPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the generated open-call.json"
    }
  }
}

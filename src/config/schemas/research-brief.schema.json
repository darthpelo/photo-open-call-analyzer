{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Research Brief Schema",
  "description": "Schema for Sebastiano's open call research output (research-brief.md). Conversational discovery layer, Cycle 1.",
  "type": "object",
  "required": ["callName", "url", "themeAnalysis", "strategicAngles", "suggestedQuestionsForArtCritic"],
  "additionalProperties": false,
  "properties": {
    "callName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "description": "Name of the open call"
    },
    "url": {
      "type": "string",
      "pattern": "^https?://",
      "description": "Open call URL"
    },
    "deadline": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Submission deadline (YYYY-MM-DD)"
    },
    "themeAnalysis": {
      "type": "string",
      "minLength": 10,
      "maxLength": 5000,
      "description": "What the call is really asking for"
    },
    "juryProfile": {
      "type": "string",
      "maxLength": 5000,
      "description": "Who the jury are, what they've awarded"
    },
    "pastWinnersPatterns": {
      "type": "string",
      "maxLength": 5000,
      "description": "Visual/thematic patterns from past winners"
    },
    "strategicAngles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["angle", "rationale"],
        "additionalProperties": false,
        "properties": {
          "angle": {
            "type": "string",
            "minLength": 3,
            "maxLength": 200,
            "description": "Positioning strategy name"
          },
          "rationale": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000,
            "description": "Why this angle could work"
          }
        }
      }
    },
    "suggestedQuestionsForArtCritic": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["question", "why"],
        "additionalProperties": false,
        "properties": {
          "question": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500,
            "description": "Question for the photographer"
          },
          "why": {
            "type": "string",
            "minLength": 3,
            "maxLength": 500,
            "description": "Why this question matters"
          }
        }
      }
    }
  }
}
